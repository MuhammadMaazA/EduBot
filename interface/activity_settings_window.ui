  <property name="styleSheet">
   <string notr="true">QWidget#ActivitySettingsWindow { background-color: #ffffff; }
QLabel#settings_title_label { background-color: #1e3a5f; color: white; font-size: 22px; font-weight: bold; padding: 20px; border-radius: 10px; }
QLabel#settings_subtitle_label { color: #1e3a5f; font-size: 13px; }
QGroupBox#robot_settings_group { background-color: #2d5a87; color: white; font-weight: bold; font-size: 12px; border: none; border-radius: 10px; padding: 16px; margin-top: 20px; }
QGroupBox#robot_settings_group::title { subcontrol-origin: margin; left: 14px; padding: 6px 10px; color: black; font-size: 16px; }
QGroupBox QLabel { color: white; }
QLabel#volume_label { margin-top: 16px; }
QGroupBox QLineEdit { background-color: #ffffff; color: #1a1a2e; border-radius: 6px; padding: 8px; min-height: 20px; }
QGroupBox QSlider::groove:horizontal { background: #4a7ab0; height: 8px; border-radius: 4px; }
QGroupBox QSlider::handle:horizontal { background: white; width: 18px; margin: -5px 0; border-radius: 9px; }
QGroupBox#robot_listening_group { background-color: #2d5a87; color: white; font-weight: bold; font-size: 12px; border: none; border-radius: 10px; padding: 16px; margin-top: 20px; }
QGroupBox#robot_listening_group::title { subcontrol-origin: margin; left: 14px; padding: 6px 10px; color: black; font-size: 16px; }
QPushButton#start_listening_button { background-color: #16a34a; color: white; font-weight: bold; padding: 10px 20px; border-radius: 8px; border: none; }
QPushButton#start_listening_button:hover { background-color: #15803d; }
QPushButton#stop_listening_button { background-color: #dc2626; color: white; font-weight: bold; padding: 10px 20px; border-radius: 8px; border: none; }
QPushButton#stop_listening_button:hover { background-color: #b91c1c; }
QPushButton#save_settings_button { background-color: #2563eb; color: white; font-weight: bold; padding: 12px 24px; border-radius: 8px; border: none; }
QPushButton#save_settings_button:hover { background-color: #1d4ed8; }
QPushButton#close_button { background-color: #64748b; color: white; font-weight: bold; padding: 12px 24px; border-radius: 8px; border: none; }
QPushButton#close_button:hover { background-color: #475569; }</string>
